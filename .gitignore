# ═══════════════════════════════════════════════════════════
# University Chatbot — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
venv/
.venv/
env/

# ── Secrets — NEVER commit these ─────────────────────────
.env

# ── Data files — may contain private university docs ─────
data/
faiss_index/
data_index/
*.index

# ── Python build artifacts ────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Node / React ──────────────────────────────────────────
node_modules/
chatbot-frontend/build/
chatbot-frontend/.env.local
chatbot-frontend/.env.production
.npm
.eslintcache

# ── OS artifacts ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────
*.log
uvicorn.log
